# Proxy Manager configuration.
# Copy to config.env and fill in your values.

# Nginx Proxy Manager API
NPM_API_URL=http://localhost:17413
NPM_EMAIL=admin@example.com
NPM_PASSWORD=changeme

# Pi-hole API (for .local DNS records)
PIHOLE_API_URL=http://localhost:17418
PIHOLE_PASSWORD=changeme
LOCAL_DNS_IP=192.168.0.122

# DNS provider for Let's Encrypt certificates
DNS_PROVIDER=duckdns
DNS_CREDENTIALS="dns_duckdns_token=your-token-here"

# Let's Encrypt email for certificate notifications
LETSENCRYPT_EMAIL=admin@example.com

# Default domain suffix for external hosts
EXTERNAL_DOMAIN_SUFFIX=yourname.duckdns.org

# Default domain suffix for internal hosts
INTERNAL_DOMAIN_SUFFIX=lan

# Default proxy host settings
DEFAULT_SCHEME=http
SSL_FORCED=true
HTTP2_SUPPORT=true
BLOCK_EXPLOITS=true
ALLOW_WEBSOCKET=true

# Certificate expiry warning threshold (days)
CERT_WARN_DAYS=30
