# ---------------------------------------------------------------------------
# Global homelab configuration template.
#
# Copy this file to `.env` (which is git-ignored) and adjust the values for
# your host. Per-stack `.env` files inside `docker-compose/<stack>/` override
# values here for the individual service that needs them.
#
# This file is committed to the repository. Never put real secrets here.
# ---------------------------------------------------------------------------

# Time zone applied by default across stacks.
# Reference: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Warsaw

# Default user/group IDs used by services that respect PUID/PGID
# (mostly LinuxServer.io images). On Docker Desktop for macOS the host UID
# is irrelevant inside the Linux VM; on a Linux host these should match the
# user that owns the bind-mount targets.
PUID=1000
PGID=1000

# Root directories for bind-mounted host data. Override per stack as needed.
# Examples:
#   Linux:   /srv/homelab
#   macOS:   /Users/<you>/homelab-data
DATA_ROOT=/path/to/data
MEDIA_ROOT=/path/to/media

# Public-facing domain for services exposed via a reverse proxy.
# Individual stacks construct their public URLs from this base.
DOMAIN=example.com
