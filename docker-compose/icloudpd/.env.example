# iCloudPD host configuration.
# Copy to `.env` and fill in your real credentials.

# Apple ID (email address).
ICLOUDPD_USERNAME=your-apple-id@example.com

# App-specific password (generate at https://appleid.apple.com/account/manage).
# Do NOT use your main Apple ID password.
ICLOUDPD_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Host path where downloaded photos will be stored.
ICLOUDPD_DOWNLOAD_PATH=/path/to/photos

# Number of recent photos to sync (default: 5000).
ICLOUDPD_RECENT=5000

TZ=Europe/Warsaw
