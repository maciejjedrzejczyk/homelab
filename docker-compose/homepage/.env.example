# Homepage host configuration.
# Copy to `.env` and adjust for your host.

HOMEPAGE_HOST_PORT=17409

# Allowed hostnames for the dashboard (comma-separated, or * for any).
# Lock this down if exposed via a reverse proxy.
HOMEPAGE_ALLOWED_HOSTS=*

# Optional: path to a folder with custom images for the dashboard.
# Set to /dev/null to disable.
HOMEPAGE_IMAGES_PATH=/path/to/images

TZ=Europe/Warsaw
