# Audiobookshelf host configuration.
# Copy to `.env` and adjust for your host.

# Host port for the web UI.
ABS_HOST_PORT=17401

# Path on the host to mount as /imported (read-only) inside the container.
# This is where you place media files for Audiobookshelf to import.
ABS_IMPORT_PATH=/path/to/imported/media

TZ=Europe/Warsaw
