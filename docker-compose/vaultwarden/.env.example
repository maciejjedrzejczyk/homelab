# Vaultwarden host configuration.
#
# Copy this file to `.env` (which is git-ignored) and edit the values for
# your host. None of the values below are sensitive — the only sensitive
# value, the admin Argon2id hash, lives in `secrets/admin_token`.

# Host port the Vaultwarden web UI listens on.
VAULTWARDEN_HOST_PORT=17421

# Public URL clients use to reach this Vaultwarden instance.
# When running behind a reverse proxy with TLS, set this to the public
# HTTPS URL. Trailing slash is optional.
DOMAIN=https://vault.example.com

# Account creation policy. Set both to false once you have created your
# personal account; otherwise anyone hitting the URL can register.
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=false

# Password hint UI. Vaultwarden shows hints on the login page by default,
# which is a small information leak.
SHOW_PASSWORD_HINT=false
PASSWORD_HINTS_ALLOWED=false

# Logging: trace, debug, info, warn, error, off
LOG_LEVEL=warn

# When running behind a reverse proxy, tell Vaultwarden which header to
# read for the real client IP. Match this to the header your proxy sets.
# Common values: X-Real-IP (Nginx), X-Forwarded-For (most), CF-Connecting-IP
# (Cloudflare).
IP_HEADER=X-Real-IP

# Optional: time zone (only affects log timestamps and password reset times).
# Reference: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Warsaw
