# Nextcloud host configuration.
# Copy to `.env` and adjust for your host.

# Host port for the Nextcloud web UI (HTTPS).
NEXTCLOUD_PORT=17411

# Host directory for Nextcloud user data (bind mount).
NEXTCLOUD_DATA_PATH=/srv/nextcloud/data

# Time zone.
TZ=Europe/Warsaw

# Database passwords. Generate with: openssl rand -base64 32
DB_PASSWORD=changeme
DB_ROOT_PASSWORD=changeme
