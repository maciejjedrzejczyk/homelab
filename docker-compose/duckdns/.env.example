# DuckDNS host configuration.
# Copy to `.env` and fill in your real token and subdomain(s).

# Your DuckDNS subdomain(s), comma-separated (without .duckdns.org).
DUCKDNS_SUBDOMAINS=mysubdomain

# Your DuckDNS token (from https://www.duckdns.org/).
DUCKDNS_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

PUID=1000
PGID=1000
TZ=Europe/Warsaw
