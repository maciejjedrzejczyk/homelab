# code-server host configuration.
# Copy to `.env` and adjust for your host.

# Host port for the web UI.
VSCODE_PORT=17425

# Workspace directory mounted into code-server.
VSCODE_WORKSPACE=/srv/homelab

# Docker group GID on the host (for socket access).
# Find with: stat -c '%g' /var/run/docker.sock
DOCKER_GID=1

# Optional: public domain if behind a reverse proxy.
VSCODE_PROXY_DOMAIN=code.example.com

# Time zone.
TZ=Europe/Warsaw
