# Immich configuration.
# Copy to `.env` and adjust for your host.
#
# Documentation: https://docs.immich.app/install/environment-variables

# The location where your uploaded files are stored.
UPLOAD_LOCATION=/path/to/photos/library

# The location where your database files are stored.
# Network shares are NOT supported for the database.
DB_DATA_LOCATION=/path/to/immich/postgres

# Time zone (optional).
# Reference: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/Warsaw

# Connection secret for PostgreSQL.
# Use only characters A-Za-z0-9, no special characters or spaces.
DB_PASSWORD=change-me-to-a-strong-random-password

# The values below this line do not need to be changed.
# ──────────────────────────────────────────────────────
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Host port for the Immich web UI (our addition, not in official template).
IMMICH_HOST_PORT=17426
